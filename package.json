{
    "name": "@miaomc/passport-sdk",
    "version": "1.0.0",
    "description": "Node.js SDK for MIAOMC Passport Apps",
    "license": "MIT",
    "author": "KumaKorin",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@types/node": "^26.0.1",
        "tsup": "^8.5.1",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "axios": "^1.18.1"
    }
}
